# ═══════════════════════════════════════════════════════════
# WebHop — Environment Variables
# Copy to .env and fill in values before running
# NEVER commit your actual .env file to git
# ═══════════════════════════════════════════════════════════

# ── Node Environment ─────────────────────────────────────────
NODE_ENV=production

# ── Backend Server ───────────────────────────────────────────
PORT=4000

# ── Database (Railway PostgreSQL or self-hosted) ─────────────
# Railway provides this automatically as DATABASE_URL
DATABASE_URL=postgresql://webhop:PASSWORD@host:5432/webhop

# Individual postgres vars (for docker-compose)
POSTGRES_PASSWORD=webhop_dev_password

# ── Authentication ────────────────────────────────────────────
# IMPORTANT: Generate a random 64-char string for production
# Use: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-64-char-secret-string-before-going-live

# ── AI APIs ───────────────────────────────────────────────────
# Required: Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: OpenAI (fallback / additional capabilities)
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Encryption ────────────────────────────────────────────────
# Exactly 32 characters — used to encrypt stored API keys
CIPHER_KEY=webhop-change-this-to-32-chars!!

# ── WordPress Engine ──────────────────────────────────────────
# URL where WordPress is accessible FROM the backend
WP_SITE_URL=http://wordpress:80

# WordPress admin credentials (auto-created on first start)
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=WebHop2024!SecureChange
WP_ADMIN_EMAIL=admin@yourdomain.com

# ── MySQL (for WordPress) ─────────────────────────────────────
MYSQL_PASSWORD=wordpress_dev_secure
MYSQL_ROOT_PASSWORD=rootpassword_secure

# ── Frontend ──────────────────────────────────────────────────
# Where the frontend is hosted (for CORS)
FRONTEND_URL=https://webhop.yourdomain.com

# Frontend build var (set during Vite build)
VITE_API_URL=/api

# ── Railway-specific ──────────────────────────────────────────
# Railway auto-injects PORT and DATABASE_URL — don't override those
# Set these in Railway's environment variable panel:
#   - ANTHROPIC_API_KEY
#   - JWT_SECRET
#   - WP_SITE_URL (URL of your WordPress Railway service)
#   - WP_ADMIN_USER
#   - WP_ADMIN_PASSWORD
#   - CIPHER_KEY
#   - FRONTEND_URL
